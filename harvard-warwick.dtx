% \begin{abstract}
% This package provides a BibLaTeX implementation of the Warwick Economics (Harvard) referencing style, based on the 13th Edition of Cite Them Right.
% \end{abstract}
%
% \section{Introduction}
% This package implements the Warwick Economics guidelines for Harvard referencing, based on Cite Them Right 12th/13th Edition.
% Notably, Warwick requires retaining the Publisher Location for books, which is omitted in standard CTR 13th Ed.
% Therefore, passing \texttt{v12=true} has no effect in this style, as it already conforms to the Warwick requirement.
% It ensures commas separate blocks, 'et al.' is used correctly, and redundant fields are hidden.
%
% \section{Usage}
% Load the package in your preamble:
% \begin{verbatim}
% \usepackage[style=harvard-warwick, backend=biber]{biblatex}
% \end{verbatim}
%

% \section{Examples}
% 
% \subsection{Books and book chapters}
% For books, use the \texttt{@book} entry type. 
% For edited book chapters, use \texttt{@incollection}.
% Ensure that editions use the suffix \texttt{edn.} automatically.

% 
% \subsubsection*{Book with author(s)}
% \begin{verbatim}
% @book{rang.etal2012rdp,
%   author = {Rang, H. P. and Dale, M. M. and Ritter, J. M. and Flower, R. J. and Henderson, G.},
%   year = {2012},
%   title = {Rang and {Dale's} Pharmacology},
%   edition = {7},
%   address = {Edinburgh},
%   publisher = {Elsevier Churchill Livingstone}}
% \end{verbatim}
% \begin{verbatim}
% @book{ou1972em,
%   author = {{Open University}},
%   year = {1972},
%   title = {Electricity and Magnetism},
%   address = {Bletchley},
%   publisher = {Open University Press}}
% \end{verbatim}
% \begin{verbatim}
% @book{solomon.etal2019cbe,
%   author = {Solomon, M. R. and Askegaard, S. and Hogg, M. and Bamossy, G. J.},
%   year = {2019},
%   title = {Consumer Behaviour: a {European} Perspective},
%   edition = {7},
%   address = {Harlow},
%   publisher = {Pearson}}
% \end{verbatim}
% 
% \subsubsection*{Book with editor(s) instead of author(s)}
% \begin{verbatim}
% @book{rothman.etal2008me,
%   editor = {Kenneth J. Rothman and Sander Greenland and Timothy L. Lash},
%   year = {2008},
%   title = {Modern Epidemiology},
%   edition = {3},
%   address = {Philadelphia, Pa.},
%   publisher = {Lippincott Williams \& Wilkins}}
% \end{verbatim}
% 
% \subsubsection*{Electronic book}
% \begin{verbatim}
% @book{haynes2014crc,
%   editor = {Haynes, W. M.},
%   year = {2014},
%   title = {{CRC} Handbook of Chemistry and Physics},
%   edition = {94},
%   address = {Boca Raton, Fla.},
%   publisher = {CRC Press/{Taylor and Francis}},
%   url = {http://www.hbcpnetbase.com},
%   urldate = {2016-06-16}}
% \end{verbatim}
% \begin{verbatim}
% @book{blockley2021evs,
%   author = {Blockley, D.},
%   year = {2021},
%   title = {Engineering: a Very Short Introduction},
%   address = {Oxford},
%   publisher = {Oxford University Press},
%   url = {https://www.amazon.co.uk/kindle},
%   urldate = {2021-06-30}}
% \end{verbatim}
% 
% \subsubsection*{Book known by its title}
% \begin{verbatim}
% @reference{bnf2020,
%   year = {2020},
%   title = {{British National Formulary}},
%   edition = {79},
%   address = {London},
%   publisher = {Pharmaceutical Press}}
% \end{verbatim}
% \begin{verbatim}
% @inreference{aspirin2020bnf,
%   title = {Aspirin},
