% \subsection{Conference papers}
% For conference proceedings, use \texttt{@inproceedings} or \texttt{@proceedings}.
% The format mirrors edited book chapters, ensuring 'in' is lowercase without a colon.

% 
% \subsubsection*{Conference paper (when proceedings have a named editor)}
% \begin{verbatim}
% @inproceedings{crawford1965oim,
